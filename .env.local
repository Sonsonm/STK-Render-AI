# =============================================================================
# STK Render AI — Variáveis de Ambiente
# Copie este arquivo para ".env.local" e preencha com os valores do seu
# projeto Supabase (Project Settings > API).
# =============================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Service Role Key — NUNCA expor ao client. Usada apenas em código server-side
# (jobs de background, scripts administrativos, processamento assíncrono).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Analysis Provider (Fase 1 - Sprint 4, ainda não usado na Sprint 0) ------
# Chave da API do provider de análise configurado em `ai_providers`.
# Mantido aqui apenas como placeholder para não quebrar o build quando
# o pipeline de IA for implementado.
ANTHROPIC_API_KEY=

# --- Render Provider (Fase 2, ainda não usado) -------------------------------
# RENDER_PROVIDER_API_KEY=
